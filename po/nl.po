msgstr "Muispijl afbeelden"

#: lib/screenshooter-dialogs.c:1025
msgid "Display the mouse pointer on the screenshot"
msgstr "Toon muispijl op de schermafdruk"

#: lib/screenshooter-dialogs.c:1032
