msgstr "Жарамсыз таңдауыңызша әрекет таңдалды"

#: lib/screenshooter-custom-actions.c:228
#, c-format
msgid "Failed to run the custom action %s"
msgstr "%s таңдаулы әрекетін орындау сәтсіз аяқталды"

