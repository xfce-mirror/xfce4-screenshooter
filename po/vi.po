#: src/main.c:77 panel-plugin/screenshooter-plugin.c:326
msgid ""
"Select a region to be captured by clicking a point of the screen without "
"releasing the mouse button, dragging your mouse to the other corner of the "
"region, and releasing the mouse button."
msgstr "Chọn vùng chụp bằng cách nhấn vào một điểm trên màn hình và không thả nút chuột, rê chuột đến góc còn lại của vùng rồi thả nút chuột."

#: src/main.c:84
msgid ""
"File path or directory where the screenshot will be saved, accepts png, jpg "
"and bmp extensions. webp, jxl and avif are only supported if their "
"respective pixbuf loaders are installed."
msgstr "Đường dẫn tập tin hoặc thư mục lưu ảnh chụp, hỗ trợ phần mở rộng png, jpg và bmp. webp, jxl và avif chỉ hỗ trợ nếu đã cài bộ tải pixbuf tương ứng."

#: src/main.c:89
msgid "Show the saved file in the folder."
msgstr "Hiển thị tập tin đã lưu trong thư mục."

#: src/main.c:94
msgid "Version information"
msgstr "Thông tin phiên bản"

#: src/main.c:104
msgid ""
"Lists supported image formats, results can vary depending on installed "
"pixbuf loaders"
msgstr "Liệt kê định dạng ảnh hỗ trợ, kết quả có thể khác nhau tùy bộ tải pixbuf đã cài"

#: src/main.c:141
#, c-format
msgid "Conflicting options: --%s and --%s cannot be used at the same time.\n"
msgstr "Tùy chọn xung đột: --%s và --%s không dùng cùng lúc.\n"

#: src/main.c:143
#, c-format
msgid ""
"The --%s option is only used when --fullscreen, --window or --region is "
"given. It will be ignored.\n"
msgstr "Tùy chọn --%s chỉ dùng khi có --fullscreen, --window hoặc --region. Sẽ bỏ qua.\n"

#: src/main.c:154
#, c-format
