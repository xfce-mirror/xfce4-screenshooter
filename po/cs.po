msgid "Capture the mouse pointer"
msgstr "Zachytit ukazatel myši"

#: lib/screenshooter-dialogs.c:1025
msgid "Display the mouse pointer on the screenshot"
msgstr "Zobrazit ukazatel myši na snímku obrazovky"

#: lib/screenshooter-dialogs.c:1032
msgid "Capture the window border"
msgstr "Zachytit okraj okna"

#: lib/screenshooter-dialogs.c:1037
msgid ""
"Display the window border on the screenshot.\n"
