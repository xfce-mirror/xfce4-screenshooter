msgstr "Zobrazit okraj okna na snímku obrazovky.\nZakázání této volby nemá vliv na okna CSD."

#: lib/screenshooter-dialogs.c:1061
msgid "<span weight=\"bold\" stretch=\"semiexpanded\">Delay before capturing</span>"
msgstr "<span weight=\"bold\" stretch=\"semiexpanded\">Prodleva před pořízením snímku</span>"

