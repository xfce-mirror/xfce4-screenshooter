#: lib/screenshooter-utils.c:326
#, c-format
msgid ""
"<b>The application could not be launched.</b>\n"
"%s"
msgstr "<b>ບໍ່ສາມາດເປີດແອັບພລິເຄຊັນໄດ້.</b>\n%s"

#: lib/screenshooter-utils.c:406
msgid "Error"
msgstr "ຂໍ້ຜິດພາດ"

#: lib/screenshooter-capture-wayland.c:198
msgid "Failed to capture screencopy frame"
msgstr "ບໍ່ສາມາດຈັບເຟຣມການສຳເນົາໜ້າຈໍໄດ້"

#: lib/screenshooter-capture-wayland.c:230
#: lib/screenshooter-capture-wayland.c:399
msgid "Failed to create file descriptor"
msgstr "ບໍ່ສາມາດສ້າງ file descriptor ໄດ້"

#: lib/screenshooter-capture-wayland.c:239
#: lib/screenshooter-capture-wayland.c:408
msgid "Failed to map memory"
msgstr "ບໍ່ສາມາດຈັບຄູ່ໜ່ວຍຄວາມຈຳ (map memory) ໄດ້"

#: lib/screenshooter-capture-wayland.c:308
msgid "Failed to capture frame"
msgstr "ບໍ່ສາມາດຈັບເຟຣມໄດ້"

#: lib/screenshooter-capture-wayland.c:386
msgid "Invalid buffer size"
msgstr ""

#: lib/screenshooter-capture-wayland.c:392
msgid "Supported format not found"
msgstr "ບໍ່ພົບຮູບແບບທີ່ຮອງຮັບ"

#: lib/screenshooter-capture-wayland.c:420
msgid "Failed to create buffer"
msgstr "ບໍ່ສາມາດສ້າງບັບເຟີ (buffer) ໄດ້"

#: lib/screenshooter-capture-wayland.c:467
msgid "Required Wayland interfaces are missing"
msgstr "ອິນເຕີເຟດ Wayland ທີ່ຈຳເປັນຂາດຫາຍໄປ"

#: lib/screenshooter-capture-wayland.c:472
msgid "Compositor is missing wl_shm"
msgstr "Compositor ຂາດ wl_shm"

#: lib/screenshooter-capture-wayland.c:477
msgid ""
"Compositor does not support wlr-screencopy-unstable-v1 nor ext-image-"
"capture-source-v1/ext-image-copy-capture-v1"
msgstr "Compositor ບໍ່ຮອງຮັບ wlr-screencopy-unstable-v1 ຫຼື ext-image-capture-source-v1/ext-image-copy-capture-v1"

#: lib/screenshooter-capture-wayland.c:588
#, c-format
msgid "Unsupported pixel format: 0x%x"
msgstr "ຮູບແບບພິກເຊວທີ່ບໍ່ຮອງຮັບ: 0x%x"

#: lib/screenshooter-capture-wayland.c:773
msgid "Failed to capture"
msgstr "ການຖ່າຍພາບລົ້ມເຫຼວ"

#: lib/screenshooter-capture-wayland.c:837
msgid "The selected mode is not supported in Wayland"
msgstr "ໂໝດທີ່ເລືອກບໍ່ຮອງຮັບໃນ Wayland"

#: src/main.c:47
msgid "Copy the screenshot to the clipboard"
msgstr "ສຳເນົາຮູບໜ້າຈໍໄປຍັງຄລິບບອດ"

#: src/main.c:52
msgid "Delay in seconds before taking the screenshot"
msgstr "ປະວິງເວລາເປັນວິນາທີກ່ອນຈະຖ່າຍຮູບໜ້າຈໍ"

#: src/main.c:62
msgid "Display the mouse on the screenshot"
msgstr "ສະແດງລູກສອນເມົາສ໌ໃນຮູບໜ້າຈໍ"

#: src/main.c:67
msgid "Removes the window border from the screenshot"
msgstr "ເອົາຂອບໜ້າຕ່າງອອກຈາກຮູບໜ້າຈໍ"

#: src/main.c:77 panel-plugin/screenshooter-plugin.c:326
msgid ""
"Select a region to be captured by clicking a point of the screen without "
"releasing the mouse button, dragging your mouse to the other corner of the "
"region, and releasing the mouse button."
msgstr "ເລືອກຂົງເຂດທີ່ຈະຖ່າຍໂດຍການຄລິກໃສ່ຈຸດໃດໜຶ່ງຂອງໜ້າຈໍແລ້ວຄ້າງໄວ້, ລາກເມົາສ໌ໄປຫາອີກມຸມໜຶ່ງຂອງຂົງເຂດ, ແລ້ວປ່ອຍປຸ່ມເມົາສ໌."

#: src/main.c:84
msgid ""
"File path or directory where the screenshot will be saved, accepts png, jpg "
"and bmp extensions. webp, jxl and avif are only supported if their "
"respective pixbuf loaders are installed."
msgstr "ເສັ້ນທາງໄຟລ໌ ຫຼື ໂຟນເດີທີ່ຈະບັນທຶກຮູບໜ້າຈໍ, ຮອງຮັບນາມສະກຸນ png, jpg ແລະ bmp. ສ່ວນ webp, jxl ແລະ avif ແມ່ນຮອງຮັບກໍ່ຕໍ່ເມື່ອໄດ້ຕິດຕັ້ງ pixbuf loader ຂອງພວກມັນແລ້ວ."

#: src/main.c:89
msgid "Show the saved file in the folder."
msgstr "ສະແດງໄຟລ໌ທີ່ບັນທຶກໄວ້ໃນໂຟນເດີ."

#: src/main.c:94
msgid "Version information"
msgstr "ຂໍ້ມູນເວີຊັນ"

#: src/main.c:104
msgid ""
"Lists supported image formats, results can vary depending on installed "
"pixbuf loaders"
msgstr "ລາຍການຮູບແບບຮູບພາບທີ່ຮອງຮັບ, ຜົນໄດ້ຮັບອາດຈະແຕກຕ່າງກັນໄປຕາມ pixbuf loaders ທີ່ຕິດຕັ້ງໄວ້"

#: src/main.c:141
#, c-format
msgid "Conflicting options: --%s and --%s cannot be used at the same time.\n"
msgstr "ຕົວເລືອກຂັດແຍ້ງກັນ: --%s ແລະ --%s ບໍ່ສາມາດໃຊ້ພ້ອມກັນໄດ້.\n"

#: src/main.c:143
#, c-format
msgid ""
"The --%s option is only used when --fullscreen, --window or --region is "
"given. It will be ignored.\n"
msgstr "ຕົວເລືອກ --%s ແມ່ນໃຊ້ໄດ້ສະເພາະເມື່ອກຳນົດ --fullscreen, --window ຫຼື --region ເທົັ້ນັ້ນ. ມັນຈະຖືກລະເລີຍ.\n"

#: src/main.c:154
#, c-format
msgid ""
"%s: %s\n"
"Try %s --help to see a full list of available command line options.\n"
msgstr "%s: %s\nລອງໃຊ້ %s --help ເພື່ອເບິ່ງລາຍການຄຳສັ່ງທັງໝົດທີ່ມີ.\n"

#: src/xfce4-screenshooter.desktop.in:5
#: panel-plugin/screenshooter.desktop.in:5
msgid ""
"Take screenshots of the entire screen, of the active window or of a region"
msgstr "ຖ່າຍຮູບໜ້າຈໍທັງໝົດ, ຖ່າຍສະເພາະໜ້າຕ່າງທີ່ໃຊ້ງານຢູ່ ຫຼື ເລືອກຂົງເຂດ"

#: src/xfce4-screenshooter.appdata.xml.in:10
msgid "xfce4-screenshooter"
msgstr "xfce4-screenshooter"

#: src/xfce4-screenshooter.appdata.xml.in:11
msgid "Application and panel plugin to take screenshots"
msgstr "ແອັບພລິເຄຊັນ ແລະ ປລັກອິນແຖບພາເນລສຳລັບຖ່າຍຮູບໜ້າຈໍ"

#: src/xfce4-screenshooter.appdata.xml.in:14
msgid ""
"Allows you to capture the entire screen, the active window or a selected "
"region. You can set the delay that elapses before the screenshot is taken "
"and the action that will be done with the screenshot: save it to a file, "
"copy it to the clipboard, open it using another application, or use your "
"creativity with custom actions."
msgstr "ຊ່ວຍໃຫ້ທ່ານສາມາດຖ່າຍຮູບໜ້າຈໍທັງໝົດ, ໜ້າຕ່າງທີ່ໃຊ້ງານຢູ່ ຫຼື ຂົງເຂດທີ່ເລືອກ. ທ່ານສາມາດຕັ້ງເວລາປະວິງກ່ອນຈະຖ່າຍ ແລະ ກຳນົດສິ່ງທີ່ຈະເຮັດກັບຮູບໜ້າຈໍໄດ້: ບັນທຶກເປັນໄຟລ໌, ສຳເນົາໄປຍັງຄລິບບອດ, ເປີດດ້ວຍແອັບພລິເຄຊັນອື່ນ ຫຼື ໃຊ້ຄວາມຄິດສ້າງສັນຂອງທ່ານກັບການດຳເນີນການກຳນົດເອງ."
